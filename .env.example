# =============================================================================
# ASTRA DISCORD BOT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control!

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Discord Bot Token (Required)
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# OpenAI API Key (Required for AI commands)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# NASA API Key (Optional - defaults to DEMO_KEY with limited usage)
# Get this from https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# Notion Integration (Optional - for task/reminder features)
# Get these from https://developers.notion.com/
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# =============================================================================
# DOCKER CONFIGURATION (Optional)
# =============================================================================

# Container name override
# CONTAINER_NAME=astra-discord-bot

# Timezone for logs (Optional)
# TZ=UTC

# =============================================================================
# DEVELOPMENT SETTINGS (Optional)
# =============================================================================

# Enable debug mode
# DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO